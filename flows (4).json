    {
        "id": "cmd-report-filter",
        "type": "function",
        "z": "tab-commands",
        "name": "Filter !report",
        "func": "const raw = (msg.payload || '').toString().trim();\nif (!raw.toLowerCase().startsWith('!report ')) return null;\nconst reportMsg = raw.slice(8).trim();\nconst author = msg.author ? (msg.author.username || 'Unknown') : 'Unknown';\nmsg.reportMsg = reportMsg;\nmsg.author = author;\nmsg.payload = { author, message: reportMsg, time: new Date().toISOString(), status: 'Open' };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 760,
        "wires": [
            [
                "cmd-report-ack",
                "cmd-report-api",
                "cmd-report-dashboard"
            ]
        ]
    },
    {
        "id": "cmd-report-ack",
        "type": "function",
        "z": "tab-commands",
        "name": "Build Ticket Ack",
        "func": "msg.payload = `🎟️ **Ticket ouvert** par **${msg.author}** :\\n> ${msg.reportMsg}\\nUn canal privé va être créé pour votre demande.`;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 720,
        "wires": [
            [
                "cmd-report-reply"
            ]
        ]
    },
