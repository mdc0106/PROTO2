    {
        "id": "cmd-report-api",
        "type": "function",
        "z": "tab-commands",
        "name": "Build Create Channel Payload",
        "func": "const channelName = `ticket-${msg.author.toLowerCase().replace(/[^a-z0-9]/g,'-').substring(0,20)}-${Date.now().toString().slice(-4)}`;\nmsg.url = 'https://discord.com/api/v10/guilds/1450828091776565442/channels';\nmsg.method = 'POST';\nmsg.headers = {\n  'Content-Type': 'application/json',\n  'Authorization': `Bot BOT_TOKEN_HERE`\n};\nmsg.payload = JSON.stringify({\n  name: channelName,\n  type: 0,\n  topic: `Ticket from ${msg.author}: ${msg.reportMsg}`,\n  permission_overwrites: []\n});\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
