    {
        "id": "cmd-router",
        "type": "function",
        "z": "tab-commands",
        "name": "Command Router",
        "func": "const raw = (msg.payload || '').toString().trim().toLowerCase();\nconst full = (msg.payload || '').toString().trim();\n\nif (raw === '!survival')   { msg.cmd = 'survival';   return [msg,null,null,null,null,null,null,null]; }\nif (raw === '!creative')   { msg.cmd = 'creative';   return [null,msg,null,null,null,null,null,null]; }\nif (raw === '!day')        { msg.cmd = 'day';        return [null,null,msg,null,null,null,null,null]; }\nif (raw === '!night')      { msg.cmd = 'night';      return [null,null,null,msg,null,null,null,null]; }\nif (raw === '!save')       { msg.cmd = 'save';       return [null,null,null,null,msg,null,null,null]; }\nif (raw === '!list')       { msg.cmd = 'list';       return [null,null,null,null,null,msg,null,null]; }\nif (raw.startsWith('!kick ')) { msg.target = full.slice(6).trim(); return [null,null,null,null,null,null,msg,null]; }\nif (raw.startsWith('!ban '))  { msg.target = full.slice(5).trim(); return [null,null,null,null,null,null,null,msg]; }\nreturn null;",
        "outputs": 8,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 360,
        "y": 100,
        "wires": [
            [
                "cmd-survival"
            ],
            [
                "cmd-creative"
            ],
            [
                "cmd-day"
            ],
            [
                "cmd-night"
            ],
            [
                "cmd-save"
            ],
            [
                "cmd-list"
            ],
            [
                "cmd-kick"
            ],
            [
                "cmd-ban"
            ]
        ]
    },
