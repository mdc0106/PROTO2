        "type": "function",
        "z": "tab-commands",
        "name": "Build Ack Message",
        "func": "const cmdMap = {\n  'gamemode survival @a': '✅ Mode **Survie** activé pour tous.',\n  'gamemode creative @a': '✅ Mode **Créatif** activé pour tous.',\n  'time set day':         '☀️ Heure réglée sur **Jour**.',\n  'time set night':       '🌙 Heure réglée sur **Nuit**.'\n};\nmsg.payload = cmdMap[msg.payload] || ('✅ Commande exécutée: ' + msg.payload);\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
