        "name": "Format Player List",
        "func": "const p = msg.payload || {};\nconst names = (p.players || []).map(x => x.name).join(', ') || 'Aucun joueur';\nmsg.payload = `👥 **${p.online || 0}/${p.max || 20}** joueurs en ligne: ${names}`;\nreturn msg;",
