    {
        "id": "mon-format-func",
        "type": "function",
        "z": "tab-monitor",
        "name": "Format Status Message",
        "func": "const p = msg.payload || {};\nconst online = p.online != null ? p.online : '?';\nconst max = p.max || 20;\nconst version = p.version || 'unknown';\nconst names = (p.players || []).map(x => x.name);\nconst nameStr = names.length > 0 ? names.join(', ') : 'Aucun';\n\nconst prev = flow.get('lastOnline');\nflow.set('lastOnline', online);\n\n// Only post if player count changed\nif (prev === online) return null;\n\nmsg.payload = {\n  content: '',\n  embeds: [{\n    title: '📊 Statut du Serveur Minecraft',\n    color: online > 0 ? 5763719 : 10038562,\n    fields: [\n      { name: '👥 Joueurs', value: `${online} / ${max}`, inline: true },\n      { name: '🎮 Version', value: version, inline: true },\n      { name: '📋 En ligne', value: nameStr, inline: false }\n    ],\n    timestamp: new Date().toISOString()\n  }]\n};\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
