    {
        "id": "evt-diff-func",
        "type": "function",
        "z": "tab-players",
        "name": "Detect Join / Leave",
        "func": "const current = (msg.payload && msg.payload.players) ? msg.payload.players.map(p => p.name) : [];\nconst prev = flow.get('playerList') || [];\nflow.set('playerList', current);\n\nconst joined = current.filter(n => !prev.includes(n));\nconst left = prev.filter(n => !current.includes(n));\n\nconst msgs = [];\njoined.forEach(name => msgs.push({ payload: `✅ **${name}** a rejoint le serveur!` }));\nleft.forEach(name =>   msgs.push({ payload: `👋 **${name}** a quitté le serveur.` }));\n\nif (msgs.length === 0) return null;\nreturn [msgs];",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
