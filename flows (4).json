        "func": "const start = flow.get('startTime') || Date.now();\nflow.set('startTime', start);\nconst s = Math.floor((Date.now() - start) / 1000);\nconst h = Math.floor(s / 3600);\nconst m = Math.floor((s % 3600) / 60);\nconst sec = s % 60;\nmsg.payload = `${h}h ${m}m ${sec}s`;\nreturn msg;",
